# ── PostgreSQL ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=traqer_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Redis ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Tuning ──
# Per-engine concurrent worker cap (each agent uses MAX_CONCURRENT_WORKERS // 3,
# floored at 1). Bump this to raise per-engine parallelism.
MAX_CONCURRENT_WORKERS=2
# A warmed profile is expired after this many minutes of inactivity.
PROFILE_TTL_MINUTES=45

# ── Browser ──
# 1 = headless (no window), 0 = show the browser window (useful for debugging).
DEBUG_HEADLESS=1

# ── Google AI Overviews (aio agent) ──
# Country (gl) and interface language (hl) for Google Search. US/English gives the
# broadest, most reliable AI Overview coverage; change only if you target a
# specific locale (note AI Overviews vary or are absent in some countries).
AIO_GL=us
AIO_HL=en

# NOTE: Proxies are NOT configured here. They live in proxies.txt
# (one host:port:user:pass per line). Run `python load_proxies.py` to load them.
