# ─────────────────────────────────────────────────────────────────────────────
# 1. Credentials & Secrets  (CRITICAL — never commit these)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
proxies.txt
proxies_list.txt
# Raw proxy exports (e.g. "Webshare 10 proxies.txt") — these contain live creds
*proxies*.txt
*Webshare*.txt
*webshare*.txt

# ─────────────────────────────────────────────────────────────────────────────
# 2. Virtual Environments
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────────────────────
# 3. Dynamic Output & Heavy Data  (regenerated at runtime)
# ─────────────────────────────────────────────────────────────────────────────
profiles/
screenshots/
logs/
*.log

# Camoufox downloads its patched Firefox + GeoIP DB into a local cache
.camoufox/
camoufox-*/

# ─────────────────────────────────────────────────────────────────────────────
# 4. Python Cache & Build
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# ─────────────────────────────────────────────────────────────────────────────
# 5. IDE, OS & Tooling
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
.agents
.claude/
graphify-out/

# ─────────────────────────────────────────────────────────────────────────────
# 6. Personal notes (not for the repo)
# ─────────────────────────────────────────────────────────────────────────────
objectives.txt
AUDIT_REPORT.md

# ─────────────────────────────────────────────────────────────────────────────
# 7. Throwaway test / debug / DOM-inspection scripts (not part of the service)
# ─────────────────────────────────────────────────────────────────────────────
test_*.py
scratch_*.py
debug_*.py

# Proxy connectivity test scripts (contain live credentials) + their output
test_bd_*.bat
*_result.html
*_test.html
google_*.html
.decodo_used_ports
# Decodo helper carries trial creds as fallback defaults — keep local
src/decodo.py

